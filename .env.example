# ========================
# DISCORD
# ========================
DISCORD_TOKEN=seu_token_discord_aqui

# ========================
# IA — CONFIGURAÇÃO FÁCIL
# ========================
# Troque AI_PROVIDER para mudar de IA sem alterar código:
#   gemini  → Google Gemini (gratuito)
#   openai  → OpenAI GPT
#   groq    → Groq (Llama, gratuito e rápido)
AI_PROVIDER=gemini

# Chave da API do provedor escolhido
# Gemini:  https://aistudio.google.com/app/apikey
# OpenAI:  https://platform.openai.com/api-keys
# Groq:    https://console.groq.com/keys
AI_API_KEY=sua_chave_api_aqui

# Modelo a usar (opcional — usa o padrão se deixar em branco)
# Gemini: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash-exp
# OpenAI: gpt-4o-mini | gpt-4o | gpt-3.5-turbo
# Groq:   llama-3.1-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
AI_MODEL=gemini-1.5-flash

# ========================
# CANAIS DO DISCORD
# ========================
# Canal onde o bot responde QUALQUER mensagem com IA
AI_CHANNEL_NAME=ia-comunidade

# Canal de boas-vindas para novos membros
WELCOME_CHANNEL_NAME=geral

# ========================
# CHROMADB CLOUD (Vector DB)
# ========================
# Banco de dados vetorial para memória de contexto e busca semântica
# Obtenha em: https://trychroma.com → Dashboard → API Keys
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=sua_api_key_chroma_aqui
CHROMA_TENANT=seu_tenant_id_aqui
CHROMA_DATABASE=dse

# ========================
# TELEGRAM
# ========================
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=seu_token_telegram_aqui
